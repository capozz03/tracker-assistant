# Timetta bearer token (required)
# Get it from your Timetta account: Settings → Integrations → API tokens
TIMETTA_TOKEN=your_timetta_bearer_token

# Tags directory ID in Timetta (optional, default value works for standard instances)
# Tags live under GET /DirectoryEntries?$filter=(directoryId eq <id>)
# Override only if your Timetta instance uses a different directory ID for tags.
TIMETTA_TAGS_DIR_ID=d7f2a0a2-c449-488e-9738-044cb99ff173
# Default Timetta project ID for submit_task.py (optional)
# Can be overridden with --project-id flag
TIMETTA_PROJECT_ID=your_timetta_project_uuid

# Telegram Bot token from @BotFather (required for task-telegram)
TELEGRAM_TOKEN=your_bot_token_from_botfather
